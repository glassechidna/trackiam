{
  "Arn": "arn:aws:iam::aws:policy/AmazonEBSCSIDriverEKSClusterScopedPolicy",
  "CreateDate": "2026-04-16T17:27:16Z",
  "DefaultVersionId": "v1",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAZKAPJZG4KUWAGAMWF",
  "PolicyName": "AmazonEBSCSIDriverEKSClusterScopedPolicy",
  "PolicyVersion": {
    "CreateDate": "2026-04-16T17:27:16Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "ec2:AttachVolume",
            "ec2:DeleteVolume",
            "ec2:DetachVolume",
            "ec2:ModifyVolume"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:volume/*",
          "Sid": "ManageClusterVolumes"
        },
        {
          "Action": [
            "ec2:AttachVolume",
            "ec2:DetachVolume"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:instance/*",
          "Sid": "AttachDetachVolumesToManuallyTaggedInstance"
        },
        {
          "Action": [
            "ec2:AttachVolume",
            "ec2:DetachVolume"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/eks:cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:instance/*",
          "Sid": "AttachDetachVolumesToClusterInstance"
        },
        {
          "Action": [
            "ec2:CopyVolumes"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:volume/vol-*",
          "Sid": "CopyClusterVolumes"
        },
        {
          "Action": [
            "ec2:CopyVolumes",
            "ec2:CreateVolume"
          ],
          "Condition": {
            "StringEquals": {
              "aws:RequestTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:volume/*",
          "Sid": "CreateAndCopyVolumesWithClusterTag"
        },
        {
          "Action": [
            "ec2:CreateSnapshot"
          ],
          "Condition": {
            "StringEquals": {
              "aws:RequestTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:snapshot/*",
          "Sid": "CreateSnapshotsWithClusterTag"
        },
        {
          "Action": [
            "ec2:CreateSnapshot"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:volume/*",
          "Sid": "CreateSnapshotsFromClusterVolumes"
        },
        {
          "Action": [
            "ec2:CreateTags"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:CreateAction": [
                "CopyVolumes",
                "CreateSnapshot",
                "CreateVolume"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": [
            "arn:aws:ec2:*:*:snapshot/*",
            "arn:aws:ec2:*:*:volume/*"
          ],
          "Sid": "TagResourcesOnCreation"
        },
        {
          "Action": [
            "ec2:CreateTags",
            "ec2:DeleteTags"
          ],
          "Condition": {
            "ForAllValues:StringNotEquals": {
              "aws:TagKeys": [
                "ebs.csi.aws.com/cluster",
                "ebs.csi.aws.com/cluster-name",
                "kubernetes.io/created-for/pvc/name"
              ]
            },
            "Null": {
              "aws:TagKeys": "false"
            },
            "StringEquals": {
              "ec2:ResourceTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:volume/*",
          "Sid": "ModifyTagsOnClusterVolumes"
        },
        {
          "Action": [
            "ec2:CreateVolume",
            "ec2:EnableFastSnapshotRestores"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:snapshot/*",
          "Sid": "CreateVolumesFromAndEnableFSROnClusterSnapshots"
        },
        {
          "Action": [
            "ec2:DeleteSnapshot",
            "ec2:LockSnapshot"
          ],
          "Condition": {
            "StringEquals": {
              "ec2:ResourceTag/ebs.csi.aws.com/cluster-name": "${aws:PrincipalTag/eks-cluster-name}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:snapshot/*",
          "Sid": "DeleteAndLockClusterSnapshots"
        },
        {
          "Action": [
            "ec2:DescribeAvailabilityZones",
            "ec2:DescribeInstanceTypes",
            "ec2:DescribeInstances",
            "ec2:DescribeSnapshots",
            "ec2:DescribeVolumeStatus",
            "ec2:DescribeVolumes",
            "ec2:DescribeVolumesModifications"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "ReadOnlyDescribeOperations"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v1"
  },
  "UpdateDate": "2026-04-16T17:27:16Z"
}
