            "aws-external-anthropic:Get*",
            "aws-external-anthropic:List*"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:aws-external-anthropic:*:*:workspace/*",
          "Sid": "AnthropicInferenceWorkspace"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
