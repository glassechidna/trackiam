{
  "Arn": "arn:aws:iam::aws:policy/aws-service-role/AWSServiceRoleForLogDeliveryPolicy",
  "CreateDate": "2019-10-04T17:31:19Z",
  "DefaultVersionId": "v5",
  "IsAttachable": true,
  "Path": "/aws-service-role/",
  "PolicyId": "ANPAZKAPJZG4EMA7ANTDG",
  "PolicyName": "AWSServiceRoleForLogDeliveryPolicy",
  "PolicyVersion": {
    "CreateDate": "2026-05-15T21:57:13Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "firehose:ListTagsForDeliveryStream",
            "firehose:PutRecord",
            "firehose:PutRecordBatch"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceTag/LogDeliveryEnabled": "true"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "LogDeliveryToFirehose"
        },
        {
          "Action": [
            "kms:Decrypt",
            "kms:GenerateDataKey"
          ],
          "Condition": {
            "StringLike": {
              "kms:ViaService": "firehose.*.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "KMSForFirehoseSSECMK"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v5"
  },
  "UpdateDate": "2026-05-15T21:57:13Z"
}
