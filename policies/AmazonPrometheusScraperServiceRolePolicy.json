{
  "Arn": "arn:aws:iam::aws:policy/aws-service-role/AmazonPrometheusScraperServiceRolePolicy",
  "CreateDate": "2023-11-26T14:19:52Z",
  "DefaultVersionId": "v3",
  "IsAttachable": true,
  "Path": "/aws-service-role/",
  "PolicyId": "ANPAZKAPJZG4MXDZTGPJI",
  "PolicyName": "AmazonPrometheusScraperServiceRolePolicy",
  "PolicyVersion": {
    "CreateDate": "2026-07-17T08:27:27Z",
    "Document": {
      "Statement": [
        {
          "Action": "aps:RemoteWrite",
          "Condition": {
            "StringEquals": {
              "aws:PrincipalAccount": "${aws:ResourceAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:aps:*:*:workspace/*",
          "Sid": "APSWriting"
        },
        {
          "Action": "cloudwatch:PutMetricData",
          "Condition": {
            "StringEquals": {
              "aws:PrincipalAccount": "${aws:ResourceAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:cloudwatch:*:*:dataset/*",
          "Sid": "CloudWatchMetricsWriting"
        },
        {
          "Action": "ec2:CreateNetworkInterface",
          "Condition": {
            "ForAllValues:StringEquals": {
              "aws:TagKeys": [
                "AMPAgentlessScraper"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "ENIManagement"
        },
        {
          "Action": "ec2:CreateTags",
          "Condition": {
            "Null": {
              "aws:RequestTag/AMPAgentlessScraper": "false"
            },
            "StringEquals": {
              "ec2:CreateAction": "CreateNetworkInterface"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:network-interface/*",
          "Sid": "TagManagement"
        },
        {
          "Action": "eks:DeleteAccessEntry",
          "Condition": {
            "ArnLike": {
              "eks:principalArn": "arn:aws:iam::*:role/aws-service-role/scraper.aps.amazonaws.com/AWSServiceRoleForAmazonPrometheusScraper*"
            },
            "StringEquals": {
              "aws:PrincipalAccount": "${aws:ResourceAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:eks:*:*:access-entry/*/role/*",
          "Sid": "DeleteEKSAccessEntry"
        },
        {
          "Action": [
            "ec2:DeleteNetworkInterface",
            "ec2:ModifyNetworkInterfaceAttribute"
          ],
          "Condition": {
            "Null": {
              "ec2:ResourceTag/AMPAgentlessScraper": "false"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "ENIUpdating"
        },
        {
          "Action": "eks:DescribeCluster",
          "Effect": "Allow",
          "Resource": "arn:aws:eks:*:*:cluster/*",
          "Sid": "EKSAccess"
        },
        {
          "Action": [
            "ec2:DescribeNetworkInterfaces",
            "ec2:DescribeSecurityGroups",
            "ec2:DescribeSubnets"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "NetworkDiscovery"
        },
        {
          "Action": [
            "iam:DeleteRole"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:iam::*:role/aws-service-role/scraper.aps.amazonaws.com/AWSServiceRoleForAmazonPrometheusScraper*",
          "Sid": "DeleteSLR"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v3"
  },
  "UpdateDate": "2026-07-17T08:27:27Z"
}
