{
  "Arn": "arn:aws:iam::aws:policy/aws-service-role/AmazonTimestreamInfluxDBServiceRolePolicy",
  "CreateDate": "2024-03-14T18:53:21Z",
  "DefaultVersionId": "v2",
  "IsAttachable": true,
  "Path": "/aws-service-role/",
  "PolicyId": "ANPAZKAPJZG4B2SEIHEWQ",
  "PolicyName": "AmazonTimestreamInfluxDBServiceRolePolicy",
  "PolicyVersion": {
    "CreateDate": "2026-07-20T18:27:24Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "cloudwatch:PutMetricData"
          ],
          "Condition": {
            "StringEquals": {
              "cloudwatch:namespace": [
                "AWS/Timestream/InfluxDB",
                "AWS/Usage"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": [
            "*"
          ],
          "Sid": "PutCloudWatchMetricsStatement"
        },
        {
          "Action": [
            "ec2:CreateNetworkInterface"
          ],
          "Condition": {
            "Null": {
              "aws:RequestTag/AmazonTimestreamInfluxDBManaged": "false"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:network-interface/*",
          "Sid": "CreateEniStatement"
        },
        {
          "Action": [
            "ec2:CreateNetworkInterfacePermission",
            "ec2:DeleteNetworkInterface"
          ],
          "Condition": {
            "Null": {
              "aws:ResourceTag/AmazonTimestreamInfluxDBManaged": "false"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:network-interface/*",
          "Sid": "ManageEniStatement"
        },
        {
          "Action": [
            "ec2:CreateTags"
          ],
          "Condition": {
            "Null": {
              "aws:RequestTag/AmazonTimestreamInfluxDBManaged": "false"
            },
            "StringEquals": {
              "ec2:CreateAction": [
                "CreateNetworkInterface"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:network-interface/*",
          "Sid": "CreateTagWithEniStatement"
        },
        {
          "Action": [
            "kms:Decrypt"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            },
            "StringLike": {
              "kms:EncryptionContext:SecretARN": "arn:*:secretsmanager:*:*:secret:InfluxDB-RepoToken-*",
              "kms:ViaService": "secretsmanager.*.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:*:kms:*:${aws:PrincipalAccount}:key/*",
          "Sid": "DecryptPluginSecretStatement"
        },
        {
          "Action": [
            "secretsmanager:CreateSecret",
            "secretsmanager:DeleteSecret"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": [
            "arn:aws:secretsmanager:*:*:secret:READONLY-InfluxDB-auth-parameters-*"
          ],
          "Sid": "ManageSecretStatement"
        },
        {
          "Action": [
            "secretsmanager:GetSecretValue"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": [
            "arn:aws:secretsmanager:*:*:secret:InfluxDB-RepoToken-*"
          ],
          "Sid": "RetrievePluginSecretStatement"
        },
        {
          "Action": [
            "ec2:CreateNetworkInterface"
          ],
          "Effect": "Allow",
          "Resource": [
            "arn:aws:ec2:*:*:security-group/*",
            "arn:aws:ec2:*:*:subnet/*"
          ],
          "Sid": "CreateEniInSubnetStatement"
        },
        {
          "Action": [
            "ec2:DescribeNetworkInterfaces",
            "ec2:DescribeSubnets",
            "ec2:DescribeVpcs"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "DescribeNetworkStatement"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v2"
  },
  "UpdateDate": "2026-07-20T18:27:24Z"
}
