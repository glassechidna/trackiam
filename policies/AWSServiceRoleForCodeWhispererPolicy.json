{
  "Arn": "arn:aws:iam::aws:policy/aws-service-role/AWSServiceRoleForCodeWhispererPolicy",
  "CreateDate": "2023-03-24T19:39:12Z",
  "DefaultVersionId": "v6",
  "IsAttachable": true,
  "Path": "/aws-service-role/",
  "PolicyId": "ANPAZKAPJZG4MTPH2EDJ3",
  "PolicyName": "AWSServiceRoleForCodeWhispererPolicy",
  "PolicyVersion": {
    "CreateDate": "2026-04-09T18:27:19Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "cloudwatch:PutMetricData"
          ],
          "Condition": {
            "StringEquals": {
              "cloudwatch:namespace": [
                "AWS/CodeWhisperer"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "sid5"
        },
        {
          "Action": [
            "kms:Decrypt"
          ],
          "Condition": {
            "ArnLike": {
              "kms:EncryptionContext:aws:identitystore:identitystore-arn": "arn:*:identitystore::*:identitystore/*"
            },
            "StringLike": {
              "kms:ViaService": "identitystore.*.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "AllowKmsAccessViaIdentityStore"
        },
        {
          "Action": [
            "kms:Decrypt"
          ],
          "Condition": {
            "ArnLike": {
              "kms:EncryptionContext:aws:sso:instance-arn": "arn:*:sso:::instance/*"
            },
            "StringLike": {
              "kms:ViaService": "sso.*.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "AllowKmsAccessViaIdentityCenter"
        },
        {
          "Action": [
            "codeguru-security:CreateScan",
            "codeguru-security:GetFindings",
            "codeguru-security:GetScan",
            "codeguru-security:ListFindings"
          ],
          "Effect": "Allow",
          "Resource": [
            "arn:aws:codeguru-security:*:*:scans/CodeWhisperer-*"
          ],
          "Sid": "sid4"
        },
        {
          "Action": [
            "codeguru-security:CreateUploadUrl"
          ],
          "Effect": "Allow",
          "Resource": [
            "*"
          ],
          "Sid": "sid3"
        },
        {
          "Action": [
            "sso-directory:ListMembersInGroup"
          ],
          "Effect": "Allow",
          "Resource": [
            "*"
          ],
          "Sid": "sid1"
        },
        {
          "Action": [
            "sso:DescribeApplication",
            "sso:DescribeInstance",
            "sso:DescribeRegisteredRegions",
            "sso:GetManagedApplicationInstance",
            "sso:GetProfile",
            "sso:ListApplicationAssignments",
            "sso:ListDirectoryAssociations",
            "sso:ListProfileAssociations",
            "sso:ListProfiles"
          ],
          "Effect": "Allow",
          "Resource": [
            "*"
          ],
          "Sid": "sid2"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v6"
  },
  "UpdateDate": "2026-04-09T18:27:19Z"
}
