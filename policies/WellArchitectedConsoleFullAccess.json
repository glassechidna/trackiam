{
  "Arn": "arn:aws:iam::aws:policy/WellArchitectedConsoleFullAccess",
  "CreateDate": "2018-11-29T18:19:23Z",
  "DefaultVersionId": "v2",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAIH6HSBHM3VSYC5SKA",
  "PolicyName": "WellArchitectedConsoleFullAccess",
  "PolicyVersion": {
    "CreateDate": "2026-07-09T17:27:22Z",
    "Document": {
      "Statement": [
        {
          "Action": "iam:CreateServiceLinkedRole",
          "Condition": {
            "StringEquals": {
              "iam:AWSServiceName": [
                "agent.wellarchitected.amazonaws.com",
                "metrics.wellarchitected.amazonaws.com",
                "wellarchitected.amazonaws.com"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "arn:*:iam::*:role/aws-service-role/*/AWSServiceRoleForWellArchitected*"
        },
        {
          "Action": "iam:PassRole",
          "Condition": {
            "StringEquals": {
              "iam:PassedToService": [
                "agent.wellarchitected.amazonaws.com",
                "wellarchitected.amazonaws.com"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:iam::*:role/*"
        },
        {
          "Action": [
            "organizations:DeregisterDelegatedAdministrator",
            "organizations:DisableAWSServiceAccess",
            "organizations:EnableAWSServiceAccess",
            "organizations:RegisterDelegatedAdministrator"
          ],
          "Condition": {
            "StringEquals": {
              "organizations:ServicePrincipal": "agent.wellarchitected.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "*"
        },
        {
          "Action": "iam:ListRoles",
          "Effect": "Allow",
          "Resource": "*"
        },
        {
          "Action": "wellarchitected:*",
          "Effect": "Allow",
          "Resource": "*"
        },
        {
          "Action": [
            "iam:AttachRolePolicy",
            "iam:CreateRole"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:iam::*:role/service-role/*"
        },
        {
          "Action": [
            "iam:CreatePolicy",
            "iam:CreatePolicyVersion",
            "iam:DeletePolicyVersion"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:iam::*:policy/service-role/*"
        },
        {
          "Action": [
            "iam:DeleteServiceLinkedRole",
            "iam:GetServiceLinkedRoleDeletionStatus"
          ],
          "Effect": "Allow",
          "Resource": "arn:*:iam::*:role/aws-service-role/*/AWSServiceRoleForWellArchitected*"
        },
        {
          "Action": [
            "organizations:DescribeAccount",
            "organizations:DescribeOrganization",
            "organizations:ListAWSServiceAccessForOrganization",
            "organizations:ListAccounts",
            "organizations:ListAccountsForParent",
            "organizations:ListDelegatedAdministrators",
            "organizations:ListDelegatedServicesForAccount",
            "organizations:ListOrganizationalUnitsForParent",
            "organizations:ListRoots"
          ],
          "Effect": "Allow",
          "Resource": "*"
        },
        {
          "Action": [
            "trustedadvisor:Get*",
            "trustedadvisor:List*"
          ],
          "Effect": "Allow",
          "Resource": "*"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v2"
  },
  "UpdateDate": "2026-07-09T17:27:22Z"
}
