{
  "Arn": "arn:aws:iam::aws:policy/aws-service-role/WAFV2LoggingServiceRolePolicy",
  "CreateDate": "2019-11-07T00:40:56Z",
  "DefaultVersionId": "v4",
  "IsAttachable": true,
  "Path": "/aws-service-role/",
  "PolicyId": "ANPAZKAPJZG4AHQ3ASNCX",
  "PolicyName": "WAFV2LoggingServiceRolePolicy",
  "PolicyVersion": {
    "CreateDate": "2026-05-20T18:12:21Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "kms:Decrypt",
            "kms:GenerateDataKey"
          ],
          "Condition": {
            "StringLike": {
              "kms:ViaService": "firehose.*.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "KMSForFirehoseSSECMK"
        },
        {
          "Action": "organizations:DescribeOrganization",
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "DescribeOrganizationAPIStatement"
        },
        {
          "Action": [
            "firehose:PutRecord",
            "firehose:PutRecordBatch"
          ],
          "Effect": "Allow",
          "Resource": [
            "arn:aws:firehose:*:*:deliverystream/aws-waf-logs-*"
          ],
          "Sid": "FirehoseAPIStatement"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v4"
  },
  "UpdateDate": "2026-05-20T18:12:21Z"
}
