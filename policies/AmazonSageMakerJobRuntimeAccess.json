{
  "Arn": "arn:aws:iam::aws:policy/AmazonSageMakerJobRuntimeAccess",
  "CreateDate": "2026-06-03T02:42:10Z",
  "DefaultVersionId": "v1",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAZKAPJZG4GOOZRIVXT",
  "PolicyName": "AmazonSageMakerJobRuntimeAccess",
  "PolicyVersion": {
    "CreateDate": "2026-06-03T02:42:10Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "sagemaker:CallWithBearerToken"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "BearerTokenPermissions"
        },
        {
          "Action": [
            "sagemaker:CompleteRollout",
            "sagemaker:Sample",
            "sagemaker:SampleWithResponseStream",
            "sagemaker:UpdateReward"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:sagemaker:*:*:job/*",
          "Sid": "SageMakerJobRuntimePermissions"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v1"
  },
  "UpdateDate": "2026-06-03T02:42:10Z"
}
