{
  "Arn": "arn:aws:iam::aws:policy/aws-service-role/AWSServiceRolePolicyForWorkspacesInstances",
  "CreateDate": "2025-06-11T20:37:06Z",
  "DefaultVersionId": "v3",
  "IsAttachable": true,
  "Path": "/aws-service-role/",
  "PolicyId": "ANPAZKAPJZG4GHC77ROUU",
  "PolicyName": "AWSServiceRolePolicyForWorkspacesInstances",
  "PolicyVersion": {
    "CreateDate": "2026-06-29T23:42:20Z",
    "Document": {
      "Statement": [
        {
          "Action": "ec2:CreateCapacityReservation",
          "Condition": {
            "StringEquals": {
              "aws:RequestTag/ManagedBy": "workspaces-instances"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "CreateCapacityReservation"
        },
        {
          "Action": "ec2:CreateTags",
          "Condition": {
            "StringEquals": {
              "aws:RequestTag/ManagedBy": "workspaces-instances"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:ec2:*:*:capacity-reservation/*",
          "Sid": "TagRemediation"
        },
        {
          "Action": [
            "ec2:CancelCapacityReservation",
            "ec2:ModifyCapacityReservation"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceTag/ManagedBy": "workspaces-instances"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "ManageTaggedCapacityReservations"
        },
        {
          "Action": [
            "ec2:CreateTags",
            "ec2:DeleteVolume",
            "ec2:StartInstances",
            "ec2:StopInstances",
            "ec2:TerminateInstances"
          ],
          "Condition": {
            "StringLike": {
              "ec2:ManagedResourceOperator": "workspaces-instances.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "ManagedInstanceOperations"
        },
        {
          "Action": [
            "ec2:DescribeCapacityReservations",
            "ec2:DescribeInstanceStatus",
            "ec2:DescribeInstances",
            "ec2:DescribeTags",
            "ec2:DescribeVolumes"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "DescribeResources"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v3"
  },
  "UpdateDate": "2026-06-29T23:42:20Z"
}
