{
  "Arn": "arn:aws:iam::aws:policy/AWSQuickSetupPatchPolicyLambdaExecutionPolicy",
  "CreateDate": "2026-06-03T14:12:26Z",
  "DefaultVersionId": "v1",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAZKAPJZG4BIVFJMYQM",
  "PolicyName": "AWSQuickSetupPatchPolicyLambdaExecutionPolicy",
  "PolicyVersion": {
    "CreateDate": "2026-06-03T14:12:26Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "iam:PassRole"
          ],
          "Condition": {
            "StringEquals": {
              "iam:PassedToService": "ssm.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:iam::*:role/AWS-QuickSetup-AutomationRole-*",
          "Sid": "PassQuickSetupAutomationRole"
        },
        {
          "Action": [
            "ssm:DescribeAssociation",
            "ssm:DescribeAssociationExecutions",
            "ssm:UpdateAssociation"
          ],
          "Effect": "Allow",
          "Resource": [
            "arn:aws:ssm:*:*:association/*",
            "arn:aws:ssm:*:*:document/AWSQuickSetup-*",
            "arn:aws:ssm:*:*:document/AWSQuickSetupType-*"
          ],
          "Sid": "ManageSSMAssociations"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
