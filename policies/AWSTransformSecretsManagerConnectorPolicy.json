{
  "Arn": "arn:aws:iam::aws:policy/AWSTransformSecretsManagerConnectorPolicy",
  "CreateDate": "2026-03-04T21:12:11Z",
  "DefaultVersionId": "v1",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAZKAPJZG4FIE5O7WIQ",
  "PolicyName": "AWSTransformSecretsManagerConnectorPolicy",
  "PolicyVersion": {
    "CreateDate": "2026-03-04T21:12:11Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "kms:Decrypt"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            },
            "StringLike": {
              "kms:EncryptionContext:SecretARN": "arn:aws:secretsmanager:${aws:RequestedRegion}:${aws:PrincipalAccount}:secret:${aws:PrincipalTag/SecretId}",
              "kms:ViaService": "secretsmanager.*.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:kms:*:*:key/${aws:PrincipalTag/KMSKeyId}",
          "Sid": "DecryptWithCustomerProvidedKMSKey"
        },
        {
          "Action": [
            "kms:DescribeKey"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:kms:*:*:key/*",
          "Sid": "DescribeKMSKey"
        },
        {
          "Action": [
            "secretsmanager:DescribeSecret",
            "secretsmanager:GetSecretValue"
          ],
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:secretsmanager:*:*:secret:${aws:PrincipalTag/SecretId}",
          "Sid": "ReadSecretsManagerSecret"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v1"
  },
  "UpdateDate": "2026-03-04T21:12:11Z"
}
