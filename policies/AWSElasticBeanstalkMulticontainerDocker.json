{
  "Arn": "arn:aws:iam::aws:policy/AWSElasticBeanstalkMulticontainerDocker",
  "CreateDate": "2016-02-08T23:15:29Z",
  "DefaultVersionId": "v5",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAJ45SBYG72SD6SHJEY",
  "PolicyName": "AWSElasticBeanstalkMulticontainerDocker",
  "PolicyVersion": {
    "CreateDate": "2026-04-29T19:27:11Z",
    "Document": {
      "Statement": [
        {
          "Action": "bedrock:InvokeModel",
          "Condition": {
            "StringEquals": {
              "aws:ResourceAccount": "${aws:PrincipalAccount}"
            }
          },
          "Effect": "Allow",
          "Resource": [
            "arn:aws:bedrock:*:*:inference-profile/*amazon.nova-*",
            "arn:aws:bedrock:*:*:inference-profile/*anthropic.claude-*"
          ],
          "Sid": "AIEnvironmentAnalysisInvokeInferenceProfile"
        },
        {
          "Action": [
            "ecs:TagResource"
          ],
          "Condition": {
            "StringEquals": {
              "ecs:CreateAction": [
                "RegisterContainerInstance",
                "StartTask"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "AllowECSTagResource"
        },
        {
          "Action": "bedrock:InvokeModel",
          "Effect": "Allow",
          "Resource": [
            "arn:aws:bedrock:*::foundation-model/amazon.nova-*",
            "arn:aws:bedrock:*::foundation-model/anthropic.claude-*"
          ],
          "Sid": "AIEnvironmentAnalysisInvokeFoundationModel"
        },
        {
          "Action": [
            "aws-marketplace:Subscribe",
            "aws-marketplace:Unsubscribe",
            "aws-marketplace:ViewSubscriptions"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "MarketplaceOperationsFromBedrock"
        },
        {
          "Action": [
            "bedrock:ListFoundationModels",
            "elasticbeanstalk:DescribeEnvironmentHealth",
            "elasticbeanstalk:DescribeEvents"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "AIEnvironmentAnalysisReadOnly"
        },
        {
          "Action": [
            "ecs:DeregisterContainerInstance",
            "ecs:DescribeContainerInstances",
            "ecs:DescribeTasks",
            "ecs:DiscoverPollEndpoint",
            "ecs:Poll",
            "ecs:RegisterContainerInstance",
            "ecs:StartTask",
            "ecs:StartTelemetrySession",
            "ecs:StopTask",
            "ecs:Submit*"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "ECSAccess"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v5"
  },
  "UpdateDate": "2026-04-29T19:27:11Z"
}
