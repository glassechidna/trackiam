{
  "Arn": "arn:aws:iam::aws:policy/AmazonS3FilesFullAccess",
  "CreateDate": "2026-04-07T12:42:08Z",
  "DefaultVersionId": "v1",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAZKAPJZG4JV3XIUHB7",
  "PolicyName": "AmazonS3FilesFullAccess",
  "PolicyVersion": {
    "CreateDate": "2026-04-07T12:42:08Z",
    "Document": {
      "Statement": [
        {
          "Action": "iam:PassRole",
          "Condition": {
            "StringEquals": {
              "iam:PassedToService": "elasticfilesystem.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:iam::*:role/*",
          "Sid": "IAMPassRoleForS3Files"
        },
        {
          "Action": [
            "events:DeleteRule",
            "events:PutRule",
            "events:PutTargets",
            "events:RemoveTargets"
          ],
          "Condition": {
            "StringEquals": {
              "events:ManagedBy": "elasticfilesystem.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": [
            "arn:aws:events:*:*:rule/DO-NOT-DELETE-S3-Files*"
          ],
          "Sid": "EventBridgeManage"
        },
        {
          "Action": "s3files:*",
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "S3FilesPermissions"
        },
        {
          "Action": [
            "ec2:CreateNetworkInterface",
            "ec2:DeleteNetworkInterface",
            "ec2:DescribeAvailabilityZones",
            "ec2:DescribeNetworkInterfaceAttribute",
            "ec2:DescribeNetworkInterfaces",
            "ec2:DescribeSecurityGroups",
            "ec2:DescribeSubnets",
            "ec2:DescribeVpcs",
            "ec2:ModifyNetworkInterfaceAttribute"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "EC2NetworkingPermissions"
        },
        {
          "Action": [
            "events:DescribeRule",
            "events:ListRules",
            "events:ListTargetsByRule"
          ],
          "Effect": "Allow",
          "Resource": [
            "arn:aws:events:*:*:rule/*"
          ],
          "Sid": "EventBridgeRead"
        },
        {
          "Action": [
            "s3:GetBucketNotification",
            "s3:PutBucketNotification"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:s3:::*",
          "Sid": "S3BucketPermissions"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v1"
  },
  "UpdateDate": "2026-04-07T12:42:08Z"
}
