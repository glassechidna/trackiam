{
  "Arn": "arn:aws:iam::aws:policy/AmazonODBFullAccess",
  "CreateDate": "2026-07-23T22:57:25Z",
  "DefaultVersionId": "v1",
  "IsAttachable": true,
  "Path": "/",
  "PolicyId": "ANPAZKAPJZG4JGUWSXDPO",
  "PolicyName": "AmazonODBFullAccess",
  "PolicyVersion": {
    "CreateDate": "2026-07-23T22:57:25Z",
    "Document": {
      "Statement": [
        {
          "Action": [
            "ec2:CreateOdbNetworkPeering",
            "ec2:DeleteOdbNetworkPeering",
            "ec2:ModifyOdbNetworkPeering"
          ],
          "Condition": {
            "ForAnyValue:StringEquals": {
              "aws:CalledVia": "odb.amazonaws.com"
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "AllowOdbNetworkPeeringActions"
        },
        {
          "Action": [
            "iam:CreateServiceLinkedRole"
          ],
          "Condition": {
            "StringEquals": {
              "iam:AWSServiceName": [
                "odb.amazonaws.com",
                "vpc-lattice.amazonaws.com"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "AllowSLRActions"
        },
        {
          "Action": [
            "ec2:DescribeAvailabilityZones",
            "ec2:DescribeVpcs"
          ],
          "Effect": "Allow",
          "Resource": "*",
          "Sid": "AllowEC2Actions"
        },
        {
