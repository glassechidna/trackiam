          "Action": [
            "ec2:RegisterImage"
          ],
          "Condition": {
            "StringEquals": {
              "aws:RequestTag/CreatedBy": "EC2 Image Builder"
            }
          },
          "Effect": "Allow",
          "Resource": [
            "arn:aws:ec2:*::image/*"
          ],
