          "Condition": {
            "StringEquals": {
              "aws:ResourceTag/CreatedBy": "EC2 Image Builder"
            }
          },
          "Effect": "Allow",
          "Resource": [
            "arn:aws:ec2:*::snapshot/*"
          ],
          "Sid": "EC2SnapshotAttributeModificationPermissions"
