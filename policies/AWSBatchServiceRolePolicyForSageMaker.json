{
  "Arn": "arn:aws:iam::aws:policy/aws-service-role/AWSBatchServiceRolePolicyForSageMaker",
  "CreateDate": "2025-07-15T21:37:06Z",
  "DefaultVersionId": "v2",
  "IsAttachable": true,
  "Path": "/aws-service-role/",
  "PolicyId": "ANPAZKAPJZG4GDK3OLQP4",
  "PolicyName": "AWSBatchServiceRolePolicyForSageMaker",
  "PolicyVersion": {
    "CreateDate": "2026-04-16T17:27:13Z",
    "Document": {
      "Statement": [
        {
          "Action": "iam:PassRole",
          "Condition": {
            "StringEquals": {
              "iam:PassedToService": [
                "sagemaker.amazonaws.com"
              ]
            }
          },
          "Effect": "Allow",
          "Resource": "*"
        },
        {
          "Action": [
            "sagemaker:AddTags"
          ],
          "Condition": {
            "StringEquals": {
              "sagemaker:TaggingAction": "CreateTrainingJob"
            }
          },
          "Effect": "Allow",
          "Resource": "arn:aws:sagemaker:*:*:training-job/AWSBatch*"
        },
        {
          "Action": [
            "sagemaker:CreateTrainingJob"
          ],
          "Effect": "Allow",
          "Resource": [
            "arn:aws:sagemaker:*:*:reserved-capacity/*",
            "arn:aws:sagemaker:*:*:training-plan/*"
          ]
        },
        {
          "Action": [
            "sagemaker:CreateTrainingJob",
            "sagemaker:DeleteTrainingJob",
            "sagemaker:DescribeTrainingJob",
            "sagemaker:ListTags",
            "sagemaker:StopTrainingJob"
          ],
          "Effect": "Allow",
          "Resource": "arn:aws:sagemaker:*:*:training-job/AWSBatch*"
        },
        {
          "Action": [
            "sagemaker:ListTrainingJobs",
            "sagemaker:Search"
          ],
          "Effect": "Allow",
          "Resource": "*"
        }
      ],
      "Version": "2012-10-17"
    },
    "IsDefaultVersion": true,
    "VersionId": "v2"
  },
  "UpdateDate": "2026-04-16T17:27:13Z"
}
